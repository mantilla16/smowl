# ============================================
#  SMOWL PROCTORING - Variables de entorno
# ============================================
# Copia este archivo como .env y completa tus credenciales reales.
# NUNCA subas .env a Git (ya está en .gitignore)

# --- API Key / Secret ---
VITE_SMOWL_API_KEY=tu_api_key_aqui
VITE_SMOWL_API_SECRET=tu_api_secret_aqui

# --- LTI Credentials ---
VITE_SMOWL_LTI_CLIENT_ID=tu_lti_client_id_aqui
VITE_SMOWL_LTI_SECRET=tu_lti_secret_aqui

# --- Identificador de tu institución en mySmowltech ---
VITE_SMOWL_ENTITY_ID=tu_entity_id_aqui

# --- URL base de la API SMOWL ---
# En desarrollo usa el proxy de Vite: /api/smowl
# En producción apunta directo: https://app.mysmowltech.com
VITE_SMOWL_BASE_URL=/api/smowl

# --- Nombre de tu aplicación (aparece en SMOWL como plataforma) ---
VITE_APP_NAME=Mi App de Examenes
